# PostgreSQL (required — schema uses provider = "postgresql")
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/revive_dev?schema=public"

# Must match the URL you open in the browser (this repo uses port 3001 in npm run dev)
NEXTAUTH_URL="https://revivedev.app"
NEXTAUTH_SECRET="YOUR_NEXTAUTH_SECRET"

GITHUB_CLIENT_ID="YOUR_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="YOUR_GITHUB_CLIENT_SECRET"

# Optional: raises GitHub Search API rate limits for Explore → Global GitHub Archive
GITHUB_TOKEN=""

RESEND_API_KEY="YOUR_RESEND_API_KEY"
EMAIL_FROM="revive.dev <noreply@revive.dev>"

# Comma-separated; must match the email on your GitHub account exactly for /admin/tickets
ADMIN_EMAILS="admin1@example.com,admin2@example.com"

# Optional: richer AI copy in diagnostics; without it, heuristics + templates are used
GEMINI_API_KEY=""
